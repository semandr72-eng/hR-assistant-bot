# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# ProxyAPI Configuration (true/false)
USE_PROXYAPI=true

# Bot Mode (text, voice, vision, rag, hr)
BOT_MODE=text

# Default Voice (alloy, echo, nova, fable, onyx, shimmer)
DEFAULT_VOICE=alloy

# Logging Configuration
LOG_LEVEL=INFO
